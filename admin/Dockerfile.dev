FROM node:22-alpine

WORKDIR /app

# Backend deps
COPY package.json ./
RUN npm install

# Frontend deps
COPY client/package.json ./client/
RUN cd client && npm install

# Source (mounted as volumes in dev)
COPY . .

EXPOSE 3002 5173

CMD ["sh", "-c", "npm run dev:backend & cd client && npm run dev -- --host"]
